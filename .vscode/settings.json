{
  "explorer.compactFolders": false,
  "chat.editor.fontSize": 16,
  "workbench.colorTheme": "One Dark Modern",
  "cSpell.language": "en,ko",
  "cSpell.enabled": false,
  "markdownlint.config": {
    "default": false
  },
  "editor.tokenColorCustomizations": {
    "[Default Dark+]": {
      "textMateRules": [
        {
          "scope": [
            "variable",
            "variable.other",
            "support.variable",
            "entity.name.variable",
            "variable.parameter"
          ],
          "settings": {
            "foreground": "#FF1493",
            "fontStyle": "bold"
          }
        }
      ]
    },
    "[One Dark Modern]": {
      "textMateRules": [
        {
          "scope": [
            "variable",
            "variable.other",
            "support.variable",
            "entity.name.variable",
            "variable.parameter"
          ],
          "settings": {
            "foreground": "#FF1493",
            "fontStyle": "bold"
          }
        }
      ]
    }
  },
  "editor.showFoldingControls": "always",
  "highlight.regexes": {
    "(wBlockQty)": [
      {
        "color": "#FF1493",
        "fontWeight": "bold"
      }
    ]
  }
}